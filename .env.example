# EDITH - Environment Configuration Template
# Copy this file to .env and fill in your actual credentials. Do not commit .env to version control!

# Intelligence Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here


# Speech & Voice Synthesizer API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
PICOVOICE_API_KEY=your_picovoice_api_key_here

# Integrations and Data APIs
WEATHER_API_KEY=your_openweathermap_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WHATSAPP_API_KEY=your_whatsapp_business_api_key_here
GOOGLE_API_KEY=your_google_cloud_credentials_or_api_key_here

# Encryption Key (Auto-generated if left empty, but specify to persist across setups)
# Run `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` to get a valid key.
EDITH_ENCRYPTION_KEY=
